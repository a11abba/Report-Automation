# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# local Codex development artifacts
.codex-*.log
.codex-*.err.log
.codex-*.png
.codex-*.html

# env files (can opt-in for committing if needed)
.env*

# local app state
/data/app-db.json
/data/app.db
/data/app.db-shm
/data/app.db-wal
/data/credential-vault.json
/data/runtime-secret.txt

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
