{
  "manifest_version": 3,
  "name": "Open API Audit Assistant",
  "version": "0.1.0",
  "description": "Internal extension for detecting account context and launching audits.",
  "permissions": ["activeTab", "scripting", "storage", "sidePanel", "tabs"],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://*.google.com/*",
    "https://*.klaviyo.com/*",
    "https://*.hubspot.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.google.com/*",
        "https://*.klaviyo.com/*",
        "https://*.hubspot.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Open API Audit Assistant"
  }
}
